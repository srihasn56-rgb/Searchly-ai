# ─── Photo Searchly AI — Environment Variables ────────────────────────────────
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# For development: place .env in the project root.
# For production builds: place .env in the same folder as the app executable,
#   or set these as system environment variables.

# ─── Google OAuth 2.0 Credentials ─────────────────────────────────────────────
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Application type: Desktop app)

CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
CLIENT_SECRET=your_google_client_secret_here

# Redirect URI — for Electron desktop app use localhost
REDIRECT_URI=http://localhost:5500/oauth2callback

# ─── Server Config ─────────────────────────────────────────────────────────────
PORT=5500
NODE_ENV=production
